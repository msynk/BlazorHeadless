@page "/"
@rendermode InteractiveServer

<PageTitle>HeadlessUI.Blazor — Component Demos</PageTitle>

<div class="demo-page">
    <header class="demo-header">
        <h1>HeadlessUI.Blazor</h1>
        <p>A headless component library for Blazor — zero styles, full accessibility, complete control.</p>
    </header>

    <section class="demo-section">
        <h2>Basic Button</h2>
        <p>Renders a native <code>&lt;button&gt;</code> with no styling. All visuals come from you.</p>

        <div class="demo-row">
            <HButton OnClick="HandleBasicClick" class="btn">
                Click me
            </HButton>
            <span class="demo-output">Clicked @basicClickCount times</span>
        </div>
    </section>

    <section class="demo-section">
        <h2>Disabled State</h2>
        <p>Sets the native <code>disabled</code> attribute and emits <code>data-disabled</code> for CSS hooks.</p>

        <div class="demo-row">
            <HButton Disabled="true" OnClick="HandleBasicClick" class="btn">
                Can't click me
            </HButton>
        </div>

        <div class="demo-attributes">
            Rendered attributes: <code>disabled</code>, <code>data-disabled</code>, <code>aria-disabled</code>
        </div>
    </section>

    <section class="demo-section">
        <h2>Loading State with Context</h2>
        <p>
            Uses <code>RenderFragment&lt;ButtonContext&gt;</code> — the Blazor equivalent of
            React render-props — so you can conditionally render a spinner driven by the button's own state.
        </p>

        <div class="demo-row">
            <HButton Loading="@isLoading" OnClick="HandleLoadingClick" class="btn" Context="btn">
                @if (btn.Loading)
                {
                    <span class="spinner"></span>
                    <span>Saving…</span>
                }
                else
                {
                    <span>Save Changes</span>
                }
            </HButton>
        </div>

        <div class="demo-attributes">
            When loading: <code>disabled</code>, <code>data-loading</code>, <code>aria-busy="true"</code>
        </div>
    </section>

    <section class="demo-section">
        <h2>Polymorphic Rendering</h2>
        <p>
            Set <code>As="a"</code> to render as an anchor tag while retaining all button semantics.
            Non-native elements automatically receive <code>role="button"</code>,
            <code>tabindex="0"</code>, and Enter/Space keyboard handling.
        </p>

        <div class="demo-row">
            <HButton As="a" href="https://github.com" target="_blank" class="btn btn-link">
                I'm actually an &lt;a&gt; tag
            </HButton>

            <HButton As="span" OnClick="HandleBasicClick" class="btn">
                I'm a &lt;span&gt; with role="button"
            </HButton>
        </div>
    </section>

    <section class="demo-section">
        <h2>Toggle Button</h2>
        <p>
            Combine <code>HButton</code> with your own state to build a toggle.
            Pass <code>aria-pressed</code> via standard HTML attributes — they merge seamlessly.
        </p>

        <div class="demo-row">
            <HButton OnClick="TogglePressed"
                     class="@ToggleClass"
                     aria-pressed="@isPressed.ToString().ToLowerInvariant()">
                @(isPressed ? "ON" : "OFF")
            </HButton>
        </div>
    </section>

    <section class="demo-section">
        <h2>Submit Button</h2>
        <p>
            Set <code>Type="submit"</code> for form submission. Works with Blazor's
            <code>EditForm</code> or plain HTML forms.
        </p>

        <div class="demo-row">
            <HButton Type="submit" OnClick="HandleSubmit" class="btn btn-primary">
                Submit Form
            </HButton>
            @if (submitted)
            {
                <span class="demo-output">Form submitted!</span>
            }
        </div>
    </section>

    <section class="demo-section">
        <h2>Styled via Data Attributes</h2>
        <p>
            The headless approach: style entirely via CSS attribute selectors.
            No component API for colors, sizes, or variants — that's your domain.
        </p>

        <div class="demo-row">
            <HButton OnClick="HandleBasicClick" class="btn-data">
                Styled via [data-*]
            </HButton>

            <HButton Disabled="true" class="btn-data">
                Disabled via [data-disabled]
            </HButton>

            <HButton Loading="true" class="btn-data">
                Loading via [data-loading]
            </HButton>
        </div>

        <pre class="demo-code"><code>/* Your CSS — the library ships none */
.btn-data              { background: #18181b; color: white; }
.btn-data[data-disabled] { opacity: 0.4; cursor: not-allowed; }
.btn-data[data-loading]  { opacity: 0.7; cursor: wait; }</code></pre>
    </section>

    <hr class="demo-divider" />
    <h2 class="demo-component-heading">Accordion</h2>

    <section class="demo-section">
        <h2>Basic Accordion (Single)</h2>
        <p>
            Only one item can be open at a time. <code>DefaultValue</code> seeds the initial open item.
            Each trigger gets <code>aria-expanded</code> and <code>aria-controls</code> automatically.
        </p>

        <HAccordion DefaultValue="item-1" class="accordion">
            <HAccordionItem Value="item-1" class="accordion-item">
                <HAccordionTrigger class="accordion-trigger" Context="t">
                    What is HeadlessUI.Blazor?
                    <span class="accordion-chevron @(t.IsOpen ? "open" : "")">▾</span>
                </HAccordionTrigger>
                <HAccordionContent class="accordion-content">
                    <div class="accordion-body">
                        HeadlessUI.Blazor is a headless component library for Blazor.
                        It provides accessible, behaviour-complete components with zero visual opinion —
                        all styling is entirely up to you.
                    </div>
                </HAccordionContent>
            </HAccordionItem>

            <HAccordionItem Value="item-2" class="accordion-item">
                <HAccordionTrigger class="accordion-trigger" Context="t">
                    Why headless?
                    <span class="accordion-chevron @(t.IsOpen ? "open" : "")">▾</span>
                </HAccordionTrigger>
                <HAccordionContent class="accordion-content">
                    <div class="accordion-body">
                        Headless means the component ships no CSS. You own the look and feel entirely.
                        Behaviour, accessibility (ARIA), and keyboard support are built in so you
                        never have to re-implement them.
                    </div>
                </HAccordionContent>
            </HAccordionItem>

            <HAccordionItem Value="item-3" class="accordion-item">
                <HAccordionTrigger class="accordion-trigger" Context="t">
                    How do I style it?
                    <span class="accordion-chevron @(t.IsOpen ? "open" : "")">▾</span>
                </HAccordionTrigger>
                <HAccordionContent class="accordion-content">
                    <div class="accordion-body">
                        Use the <code>data-state="open"|"closed"</code> attribute on any element
                        for CSS transitions, or just apply classes. The library emits no
                        inline styles and no class names of its own.
                    </div>
                </HAccordionContent>
            </HAccordionItem>
        </HAccordion>
    </section>

    <section class="demo-section">
        <h2>Multiple Open Items</h2>
        <p>
            Set <code>Type="AccordionType.Multiple"</code> to allow any number of panels to
            be open simultaneously.
        </p>

        <HAccordion Type="AccordionType.Multiple" class="accordion">
            <HAccordionItem Value="faq-1" class="accordion-item">
                <HAccordionTrigger class="accordion-trigger" Context="t">
                    Can I open multiple panels?
                    <span class="accordion-chevron @(t.IsOpen ? "open" : "")">▾</span>
                </HAccordionTrigger>
                <HAccordionContent class="accordion-content">
                    <div class="accordion-body">
                        Yes! With <code>Type="AccordionType.Multiple"</code> all panels are independent
                        and any combination may be open at the same time.
                    </div>
                </HAccordionContent>
            </HAccordionItem>

            <HAccordionItem Value="faq-2" class="accordion-item">
                <HAccordionTrigger class="accordion-trigger" Context="t">
                    Does this one close when I open another?
                    <span class="accordion-chevron @(t.IsOpen ? "open" : "")">▾</span>
                </HAccordionTrigger>
                <HAccordionContent class="accordion-content">
                    <div class="accordion-body">
                        No — both can be open at once. Try opening both panels now!
                    </div>
                </HAccordionContent>
            </HAccordionItem>
        </HAccordion>
    </section>

    <section class="demo-section">
        <h2>Disabled Item</h2>
        <p>
            Individual items can be disabled via <code>Disabled="true"</code> on
            <code>HAccordionItem</code>. The entire accordion can be disabled at the root.
        </p>

        <HAccordion class="accordion">
            <HAccordionItem Value="d-1" class="accordion-item">
                <HAccordionTrigger class="accordion-trigger" Context="t">
                    I am enabled
                    <span class="accordion-chevron @(t.IsOpen ? "open" : "")">▾</span>
                </HAccordionTrigger>
                <HAccordionContent class="accordion-content">
                    <div class="accordion-body">This item works normally.</div>
                </HAccordionContent>
            </HAccordionItem>

            <HAccordionItem Value="d-2" Disabled="true" class="accordion-item">
                <HAccordionTrigger class="accordion-trigger" Context="t">
                    I am disabled
                    <span class="accordion-chevron @(t.IsOpen ? "open" : "")">▾</span>
                </HAccordionTrigger>
                <HAccordionContent class="accordion-content">
                    <div class="accordion-body">You should not be able to open this.</div>
                </HAccordionContent>
            </HAccordionItem>
        </HAccordion>
    </section>

    <section class="demo-section">
        <h2>Controlled Accordion</h2>
        <p>
            Drive open state externally with <code>Value</code> and <code>OnValueChange</code>.
            The button below toggles the second panel programmatically.
        </p>

        <div class="demo-row" style="margin-bottom: 1rem;">
            <HButton OnClick="ToggleControlledItem" class="btn">
                Toggle "Panel 2"
            </HButton>
            <span class="demo-output">Open: @(controlledValue ?? "none")</span>
        </div>

        <HAccordion Value="@controlledValue" OnValueChange="v => controlledValue = v" class="accordion">
            <HAccordionItem Value="ctrl-1" class="accordion-item">
                <HAccordionTrigger class="accordion-trigger" Context="t">
                    Panel 1
                    <span class="accordion-chevron @(t.IsOpen ? "open" : "")">▾</span>
                </HAccordionTrigger>
                <HAccordionContent class="accordion-content">
                    <div class="accordion-body">Controlled by external state.</div>
                </HAccordionContent>
            </HAccordionItem>

            <HAccordionItem Value="ctrl-2" class="accordion-item">
                <HAccordionTrigger class="accordion-trigger" Context="t">
                    Panel 2
                    <span class="accordion-chevron @(t.IsOpen ? "open" : "")">▾</span>
                </HAccordionTrigger>
                <HAccordionContent class="accordion-content">
                    <div class="accordion-body">This panel is toggled by the button above.</div>
                </HAccordionContent>
            </HAccordionItem>
        </HAccordion>

        <pre class="demo-code" style="margin-top:1rem"><code>/* Attributes emitted on the trigger */
button[aria-expanded="true"]  { /* open state  */ }
button[aria-expanded="false"] { /* closed state */ }
[data-state="open"]   { /* open  */ }
[data-state="closed"] { /* closed */ }</code></pre>
    </section>
</div>

@code {
    private int basicClickCount;
    private bool isLoading;
    private bool isPressed;
    private bool submitted;

    // Accordion — controlled demo
    private string? controlledValue;

    private string ToggleClass => isPressed ? "btn btn-toggle active" : "btn btn-toggle";

    private void HandleBasicClick()
    {
        basicClickCount++;
    }

    private async Task HandleLoadingClick()
    {
        isLoading = true;
        await Task.Delay(2000);
        isLoading = false;
    }

    private void TogglePressed()
    {
        isPressed = !isPressed;
    }

    private void HandleSubmit()
    {
        submitted = true;
    }

    private void ToggleControlledItem()
    {
        controlledValue = controlledValue == "ctrl-2" ? null : "ctrl-2";
    }
}
